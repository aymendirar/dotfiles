{
  "workbench.settings.editor": "json",
  "workbench.editor.enablePreview": false,
  "workbench.sideBar.location": "right",
  "workbench.iconTheme": "catppuccin-macchiato",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.editor.restoreViewState": false,
  "workbench.settings.openDefaultSettings": true,
  "workbench.settings.useSplitJSON": true,
  "workbench.list.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontFamily": "BerkeleyMono Nerd Font Mono",
  "editor.fontWeight": "Bold",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.matchBrackets": "never",
  "editor.autoIndent": "full",
  "editor.columnSelection": false,
  "editor.cursorStyle": "block",
  "editor.cursorBlinking": "solid",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.cursorSurroundingLines": 9999,
  "editor.smoothScrolling": true,
  "window.restoreWindows": "none",
  "window.titleBarStyle": "custom",
  "window.zoomLevel": -1.0,
  "explorer.compactFolders": false,
  "terminal.integrated.lineHeight": 1,
  "terminal.integrated.letterSpacing": 1,
  "terminal.integrated.fontFamily": "BerkeleyMono Nerd Font Mono",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontWeight": "Regular",
  "terminal.integrated.copyOnSelection": true,
  "gitlens.currentLine.fontFamily": "BerkeleyMono Nerd Font Mono",
  "gitlens.codeLens.enabled": true,
  "editor.formatOnSave": true,
  "prettier.requireConfig": true,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": null,
    "editor.formatOnSave": false
  },
  "gopls": {
    "build.buildFlags": [
      "-mod=readonly"
    ]
  },
  "python.defaultInterpreterPath": "/usr/local/bin/python3",
  "python.languageServer": "None",
  "vim.useCtrlKeys": true,
  "vim.camelCaseMotion.enable": true,
  "vim.cursorStylePerMode.visual": "block",
  "vim.cursorStylePerMode.visualblock": "block",
  "vim.cursorStylePerMode.visualline": "block",
  "vim.leader": " ",
  "vim.startofline": false,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "u"
      ],
      "commands": [
        "undo"
      ]
    },
    {
      "before": [
        "<C-r>"
      ],
      "commands": [
        "redo"
      ]
    },
    {
      "before": [
        "j"
      ],
      "after": [
        "j",
        "z",
        "z"
      ]
    },
    {
      "before": [
        "k"
      ],
      "after": [
        "k",
        "z",
        "z"
      ]
    },
    {
      "before": [
        "<C-d>"
      ],
      "after": [
        "<C-d>",
        "z",
        "z"
      ]
    },
    {
      "before": [
        "<C-u>"
      ],
      "after": [
        "<C-u>",
        "z",
        "z"
      ]
    },
    {
      "before": [
        "<leader>",
        "t",
        "s"
      ],
      "commands": [
        "workbench.files.action.showActiveFileInExplorer"
      ]
    },
    {
      "before": [
        "<leader>",
        "t",
        "r"
      ],
      "commands": [
        "revealInExplorer"
      ]
    },
    {
      "before": [
        "leader",
        "g",
        "d"
      ],
      "commands": [
        "git.openChange"
      ]
    },
    {
      "before": [
        "g",
        "t"
      ],
      "commands": [
        "editor.action.goToTypeDefinition"
      ]
    },
    {
      "before": [
        "g",
        "r"
      ],
      "commands": [
        "editor.action.goToReferences"
      ]
    },
    {
      "before": [
        "<leader>",
        "r"
      ],
      "commands": [
        "editor.action.rename"
      ]
    },
    {
      "before": [
        "<leader>",
        "q",
        "h"
      ],
      "commands": [
        "workbench.action.closeEditorsToTheLeft"
      ]
    },
    {
      "before": [
        "<leader>",
        "q",
        "l"
      ],
      "commands": [
        "workbench.action.closeEditorsToTheRight"
      ]
    },
    {
      "before": [
        "<leader>",
        "q",
        "x"
      ],
      "commands": [
        "workbench.action.closeOtherEditors"
      ]
    },
    {
      "before": [
        "<leader>",
        "h"
      ],
      "commands": [
        "workbench.action.navigateLeft"
      ]
    },
    {
      "before": [
        "<leader>",
        "o"
      ],
      "commands": [
        "git.openFile"
      ]
    },
    {
      "before": [
        "<leader>",
        "l"
      ],
      "commands": [
        "workbench.action.navigateRight"
      ]
    },
    {
      "before": [
        "<leader>",
        "j"
      ],
      "commands": [
        "workbench.action.navigateDown"
      ]
    },
    {
      "before": [
        "<leader>",
        "k"
      ],
      "commands": [
        "workbench.action.navigateUp"
      ]
    },
    {
      "before": [
        "<leader>",
        "i"
      ],
      "commands": [
        "workbench.action.nextEditor"
      ]
    },
    {
      "before": [
        "<leader>",
        "u"
      ],
      "commands": [
        "workbench.action.previousEditor"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "w"
      ],
      "commands": [
        "editor.action.formatDocument",
        "workbench.action.files.save"
      ]
    },
    {
      "before": [
        "<leader>",
        "s",
        "p"
      ],
      "commands": [
        "workbench.action.findInFiles"
      ]
    },
    {
      "before": [
        "<leader>",
        "p"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "<leader>",
        "c",
        "p"
      ],
      "commands": [
        "copyRelativeFilePath"
      ]
    },
    {
      "before": [
        "<leader>",
        "a"
      ],
      "commands": [
        "editor.action.quickFix"
      ]
    },
    {
      "before": [
        "<leader>",
        "s",
        "f"
      ],
      "commands": [
        "workbench.action.editor.changeLanguageMode"
      ]
    },
    {
      "before": [
        "<leader>",
        "d"
      ],
      "commands": [
        "editor.toggleFold"
      ]
    }
  ],
  "vim.normalModeKeyBindings": [
    {
      "before": [
        "<leader>",
        "n"
      ],
      "after": [
        "^"
      ]
    },
    {
      "before": [
        "K"
      ],
      "commands": [
        "editor.action.showHover"
      ]
    },
    {
      "before": [
        "T"
      ],
      "commands": [
        "editor.action.peekTypeDefinition"
      ]
    },
    {
      "before": [
        "Y"
      ],
      "after": [
        "y",
        "$"
      ]
    }
  ],
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<esc>"
      ]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": [
        "leader",
        "g",
        "y"
      ],
      "commands": [
        "gitlens.copyRemoteFileUrlToClipboard"
      ]
    },
    {
      "before": [
        "<leader>",
        "c"
      ],
      "commands": [
        "editor.action.commentLine"
      ]
    }
  ],
  "vim.autoindent": true,
  "vim.hlsearch": true,
  "vim.useSystemClipboard": true,
  "vim.easymotion": true,
  "vim.surround": true,
  "vim.foldfix": true,
  "terminal.integrated.gpuAcceleration": "on",
  "security.workspace.trust.untrustedFiles": "open",
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": false,
  "workbench.colorCustomizations": {},
  "workbench.settings.applyToAllProfiles": [],
  "terraform.languageServer.enable": true,
  "chat.commandCenter.enabled": false,
  "window.commandCenter": true,
  "security.workspace.trust.enabled": true,
  "redhat.telemetry.enabled": false,
  "remote.SSH.remotePlatform": {
    "coder-vscode.coder.figdev.systems--adirar--aymen-devbox-5.devcontainer": "linux",
    "coder-vscode.coder.figdev.systems--adirar--aymen-devbox-3.devcontainer": "linux",
    "coder-vscode.coder.figdev.systems--adirar--aymen-devbox-2.devcontainer": "linux",
    "coder-vscode.coder.figdev.systems--adirar--aymen-devbox-4.devcontainer": "linux"
  },
  "remote.SSH.connectTimeout": 1800,
  "remote.SSH.reconnectionGraceTime": 28800,
  "remote.SSH.serverShutdownTimeout": 28800,
  "remote.SSH.maxReconnectionAttempts": null,
  "workbench.colorTheme": "Catppuccin Macchiato",
  "cursorBlame.editorDecoration.enabled": false,
  "remote.autoForwardPortsSource": "hybrid",
  "scm.autoReveal": true,
}